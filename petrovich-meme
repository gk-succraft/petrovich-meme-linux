#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -n "${STICKER_DIR:-}" ]]; then
    : # user override
elif [[ -d "$SCRIPT_DIR/stickers" ]]; then
    STICKER_DIR="$SCRIPT_DIR/stickers"          # dev / cloned repo
else
    STICKER_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/petrovich-meme/stickers"  # installed
fi

WINDOW_TITLE="${STICKER_PICKER_TITLE:-Stickers}"
mkdir -p "$STICKER_DIR"

# ---- deps ----
die() { echo "ERROR: $*" >&2; exit 1; }
missing() {
    local bin="$1"
    if [[ -f /etc/NIXOS ]] || [[ -n "${NIX_PATH:-}" ]]; then
        die "$bin not found. Run: nix develop"
    else
        die "$bin not found. Install with your package manager"
    fi
}

is_wayland() {
    [[ -n "${WAYLAND_DISPLAY:-}" ]] || [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]]
}

command -v feh &>/dev/null    || missing "feh"

if is_wayland; then
    command -v wl-copy &>/dev/null || missing "wl-clipboard"
else
    command -v xclip &>/dev/null || missing "xclip"
fi

# ---- stickers ----
shopt -s nullglob
FILES=("$STICKER_DIR"/*.{png,jpg,jpeg,gif,webp,bmp})
if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "No images in $STICKER_DIR" >&2
    exit 0
fi

# ---- copy command ----
if is_wayland; then
    COPY_CMD='wl-copy --type image/png < %f && kill $PPID'
else
    COPY_CMD='xclip -selection clipboard -target image/png -i %f && kill $PPID'
fi

# ---- launch ----
feh -t \
    -E 130 -y 130 \
    -W 820 \
    --index-info '' \
    --title "$WINDOW_TITLE" \
    --action1 "$COPY_CMD" \
    --draw-actions \
    "$STICKER_DIR" &
FEH_PID=$!

for _ in $(seq 1 20); do
    sleep 0.1
    if WID=$(xdotool search --pid "$FEH_PID" 2>/dev/null | head -1); then
        xdotool set_window --name "$WINDOW_TITLE" "$WID" 2>/dev/null && break
    fi
done

wait "$FEH_PID"
